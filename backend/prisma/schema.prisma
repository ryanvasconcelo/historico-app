generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model LegacyConversation {
  id           String   @id @default(cuid())
  contactPhone String
  contactName  String?
  startedAt    DateTime?
  endedAt      DateTime?
  source       String?
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())

  messages     LegacyMessage[]

  @@index([contactPhone])
  @@index([endedAt])
  @@map("legacy_conversations")
}

model LegacyMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderName     String?
  senderType     String?
  content        String
  sentAt         DateTime?
  contentHash    String   @unique
  createdAt      DateTime @default(now())

  conversation   LegacyConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([sentAt])
  @@map("legacy_messages")
}

model ImportBatch {
  id                 String   @id @default(cuid())
  fileName           String
  status             String
  totalMessages      Int      @default(0)
  totalConversations Int      @default(0)
  totalRejected      Int      @default(0)
  startedAt          DateTime @default(now())
  finishedAt         DateTime?
  createdAt          DateTime @default(now())

  @@map("import_batches")
}

model ImportRejectedLine {
  id         String   @id @default(cuid())
  batchId    String
  lineNumber Int?
  content    String
  reason     String?
  createdAt  DateTime @default(now())

  @@index([batchId])
  @@map("import_rejected_lines")
}
